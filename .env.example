# ============================================================
# Customer Success Digital FTE — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# PostgreSQL (docker-compose overrides host to "postgres")
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/customer_success
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# Kafka (docker-compose overrides to "kafka:29092")
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# App
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
