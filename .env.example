# ============================================================
# Customer Success Digital FTE — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# PostgreSQL (Neon.tech)
DATABASE_URL=postgresql+psycopg://neondb_owner:npg_5v8OKTuViXQe@ep-wild-water-apbibthl-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# Kafka (docker-compose overrides to "kafka:29092")
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# x.ai (Grok) — OpenAI-compatible
XAI_API_KEY=your-xai-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.20-reasoning

# App
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# --- Gmail Integration (SMTP) ---
# Get an App Password: Google Account > Security > 2-Step Verification > App Passwords
GMAIL_EMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_FROM_NAME=Customer Success AI

# --- WhatsApp Cloud API (legacy) ---
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_API_URL=https://graph.facebook.com/v21.0

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=your-twilio-whatsapp-number

